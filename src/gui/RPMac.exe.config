<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0" />
  </startup>
  <runtime>
    <!-- Deliver corrupted-state exceptions (e.g. AccessViolation from the native I/O
         driver) to managed handlers so they can be caught/logged instead of silently
         killing the process. -->
    <legacyCorruptedStateExceptionsPolicy enabled="true" />
  </runtime>
</configuration>
